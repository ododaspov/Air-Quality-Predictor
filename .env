# =============================================================
#  Nairobi Air Quality Project — Environment Variables
#  DO NOT commit this file to Git. Add .env to .gitignore
# =============================================================

# ── OpenAfrica Dataset URL ───────────────────────────────────
DATA_URL=https://open.africa/dataset/44359020-b2b0-4b66-af09-3de18d6519dc/resource/d8bb7a86-fef9-4206-9616-3591daff36f1/download/tmp7ac1ezhw.csv

# ── Pipeline Settings ────────────────────────────────────────
# How often (seconds) the scheduler polls OpenAfrica for new data
POLL_INTERVAL_SECONDS=300

# Retrain model if recent MAE (µg/m³) exceeds this threshold
RETRAIN_MAE_THRESHOLD=10.0

# Force retrain every N successful data updates (regardless of MAE)
FORCE_RETRAIN_EVERY_N=12

# ── File Paths (relative to project root) ───────────────────
HIST_PATH=historical_data.csv
MODEL_PATH=air_quality_model.pkl
METRICS_PATH=model_metrics.csv
FEAT_IMP_PATH=feature_importances.csv
DRIFT_PATH=drift_report.csv
AUDIT_LOG_PATH=pipeline_audit.log
RETRAIN_LOG_PATH=retrain_log.json
STATUS_PATH=update_status.json

# ── Request Settings ─────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30

# ── Model Settings ───────────────────────────────────────────
# "rf" = Random Forest | "gb" = Gradient Boosting
MODEL_TYPE=rf
