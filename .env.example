# =============================================================
#  .env.example — copy this to .env and fill in your values
#  This file IS safe to commit to Git
# =============================================================

# ── OpenAfrica Dataset URL ───────────────────────────────────
DATA_URL=https://open.africa/dataset/<your-dataset-id>/resource/<resource-id>/download/<file>.csv

# ── Pipeline Settings ────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
RETRAIN_MAE_THRESHOLD=10.0
FORCE_RETRAIN_EVERY_N=12

# ── File Paths ───────────────────────────────────────────────
HIST_PATH=historical_data.csv
MODEL_PATH=air_quality_model.pkl
METRICS_PATH=model_metrics.csv
FEAT_IMP_PATH=feature_importances.csv
DRIFT_PATH=drift_report.csv
AUDIT_LOG_PATH=pipeline_audit.log
RETRAIN_LOG_PATH=retrain_log.json
STATUS_PATH=update_status.json

# ── Request Settings ─────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30

# ── Model Settings ───────────────────────────────────────────
MODEL_TYPE=rf
